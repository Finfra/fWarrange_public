            "value" : "Alle gespeicherten Layout-Dateien werden dauerhaft gelöscht. Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All saved layout files will be permanently deleted. This action cannot be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
