%% title: fWarrange - 컴포넌트 아키텍처 다이어그램
%% svgPath: _doc_design/DIAGRAM_COMPONENT.svg

graph TB
    subgraph "🎮 Application Layer"
        APP["🏁fWarrangeApp<br/>앱 라이프사이클 및 의존성 주입"]
        AD["⚙️AppDelegate<br/>재실행 및 메뉴바 관리"]
    end

    subgraph "🌐 REST API Layer"
        REST["🌐RESTServer<br/>NWListener 기반 HTTP 서버<br/>12개 엔드포인트"]
    end

    subgraph "🖼️ UI View Layer"
        CV["🖥ContentView<br/>메인 윈도우 UI"]
        MBCV["🔝MenuBarContentView<br/>메뉴바 팝오버 (빠른 복구/저장)"]
        SV["🎛SettingsSheet<br/>설정 UI (5탭: 일반/단축키/복구/API/고급)"]
        LDV["📊LayoutDetailView<br/>레이아웃 상세 정보"]
        LLV["📋LayoutListView<br/>레이아웃 목록 (검색, 정렬)"]
    end

    subgraph "🧠 ViewModel Layer"
        MVM["MainViewModel<br/>전체 상태 및 비즈니스 로직 관장"]
    end

    subgraph "⚙️ Manager Layer"
        WM["🪟WindowManager<br/>창 캡처/복구 코디네이션"]
        LM["📂LayoutManager<br/>레이아웃 데이터 및 메타데이터 관리"]
    end

    subgraph "🛠️ Service Layer"
        WCS["📷WindowCaptureService<br/>CoreGraphics 창 정보 획득"]
        WRS["🔧WindowRestoreService<br/>Accessibility 창 배치"]
        LSS["💾LayoutStorageService<br/>YAML 파일 입출력"]
        SS["⚙️SettingsService<br/>UserDefaults 연동"]
        HKS["⌨️HotKeyService<br/>Global 단축키 모니터링"]
        ACS["🛡AccessibilityService<br/>시스템 권한 확인"]
    end

    subgraph "📦 Data Models Layer"
        WI["📱WindowInfo<br/>단일 창 정보"]
        L["📐Layout<br/>레이아웃 (복수 WindowInfo)"]
        LM_Meta["🏷LayoutMetadata<br/>목록용 정보"]
        AS["⚙️AppSettings<br/>앱 설정 데이터"]
        WMR["✅WindowMatchResult<br/>창 매칭 성공 결과"]
    end

    subgraph "📁 Infrastructure / System"
        CG["CoreGraphics API"]
        AX["Accessibility API"]
        FS["File System: YAML"]
        UD["UserDefaults"]
        SMAPP["ServiceManagement<br/>Launch at Login"]
        NE["NSEvent<br/>Global/Local Monitor"]
        NW["Network.framework<br/>NWListener + NWConnection"]
    end

    %% Application Initialization
    APP -->|생성 & 주입| MVM
    APP -->|생성 & 주입| REST
    APP -->|호스팅| CV
    APP -->|호스팅| MBCV
    APP -->|위임| AD

    %% REST API Dependencies
    REST -->|직접 호출| WM
    REST -->|직접 호출| LM
    REST -->|설정 읽기| SS
    REST -->|HTTP 수신| NW
    REST -.->|Notification| MVM

    %% UI to ViewModel Dependencies
    CV -->|관찰| MVM
    MBCV -->|관찰| MVM
    SV -->|상태 제어| MVM
    LDV -->|레이아웃 조회| MVM
    LLV -->|레이아웃 변경| MVM

    %% ViewModel to Manager/Service Dependencies
    MVM -->|요청| WM
    MVM -->|요청| LM
    MVM -->|저장/불러오기| SS
    MVM -->|등록/해제| HKS
    MVM -->|상태 유지| AS

    %% Manager to Service Dependencies
    WM -->|호출| WCS
    WM -->|호출| WRS
    WM -->|호출| ACS

    LM -->|저장/로드| LSS

    %% Service to Infrastructure Dependencies
    WCS -->|읽기| CG
    WRS -->|제어| AX
    ACS -->|확인| AX
    LSS -->|I/O| FS
    SS  -->|저장/읽기| UD
    HKS -->|이벤트 감시| NE
    MVM -.->|자동실행 제어| SMAPP

    %% Data Flow
    WCS -->|생성| WI
    WRS -->|결과| WMR
    LSS -->|생성| L
    LSS -->|생성| LM_Meta

    classDef appLayer fill:#e3f2fd,stroke:#1976d2,stroke-width:2px
    classDef uiLayer fill:#e8f5e8,stroke:#388e3c,stroke-width:2px
    classDef vmLayer fill:#f3e5f5,stroke:#7b1fa2,stroke-width:3px
    classDef managerLayer fill:#fff3e0,stroke:#f57c00,stroke-width:2px
    classDef serviceLayer fill:#fce4ec,stroke:#c2185b,stroke-width:2px
    classDef modelLayer fill:#e0f2f1,stroke:#00695c,stroke-width:2px
    classDef infraLayer fill:#eceff1,stroke:#607d8b,stroke-width:2px
    classDef restLayer fill:#e8eaf6,stroke:#3f51b5,stroke-width:2px

    class APP,AD appLayer
    class CV,MBCV,SV,LDV,LLV uiLayer
    class MVM vmLayer
    class WM,LM managerLayer
    class WCS,WRS,LSS,SS,HKS,ACS serviceLayer
    class WI,L,LM_Meta,AS,WMR modelLayer
    class CG,AX,FS,UD,SMAPP,NE,NW infraLayer
    class REST restLayer
